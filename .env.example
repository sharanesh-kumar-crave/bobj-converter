# ─── HANA Cloud (local dev — ignored in CF where VCAP_SERVICES is used) ───────
HANA_HOST=localhost
HANA_PORT=39017
HANA_USER=SYSTEM
HANA_PASSWORD=
HANA_ENCRYPT=false
HANA_POOL_SIZE=3

# ─── SAP AI Core ──────────────────────────────────────────────────────────────
# Leave blank to fall back to direct Anthropic API (local dev mode)
AICORE_DEPLOYMENT_ID=
AICORE_RESOURCE_GROUP=default

# ─── Anthropic API (local dev fallback only) ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── SAP Datasphere ───────────────────────────────────────────────────────────
DATASPHERE_BASE_URL=https://<tenant>.eu20.hana.ondemand.com
DATASPHERE_SPACE_ID=<your-space-id>
DATASPHERE_TOKEN_URL=https://<tenant>.authentication.eu20.hana.ondemand.com/oauth/token
DATASPHERE_CLIENT_ID=
DATASPHERE_CLIENT_SECRET=

# ─── SAP Analytics Cloud ──────────────────────────────────────────────────────
SAC_TENANT_URL=https://<tenant>.eu20.sapanalytics.cloud
SAC_TOKEN_URL=https://<tenant>.authentication.eu20.hana.ondemand.com/oauth/token
SAC_CLIENT_ID=
SAC_CLIENT_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
